# Backend OAuth do Bling
# Copie estas variáveis para o serviço onde o backend FastAPI será hospedado.

BLING_CLIENT_ID=cole_aqui_o_client_id_do_app_v3_bling
BLING_CLIENT_SECRET=cole_aqui_o_client_secret_do_app_v3_bling
BLING_REDIRECT_URI=https://SEU-BACKEND.com/auth/bling/callback
FRONTEND_RETURN_URL=https://ia-planilhas.streamlit.app/

# Opcional. No Render Free use /tmp; para produção, prefira armazenamento persistente.
BLING_BACKEND_TOKEN_DIR=/tmp/bling_tokens
